{
  "name": "content-distribution-mcp",
  "version": "1.0.1",
  "description": "MCP server for multi-platform content distribution — publish to LinkedIn, Instagram, X/Twitter, TikTok, and more from any AI agent",
  "mcpName": "io.github.gomessoaresemmanuel-cpu/content-distribution-mcp",
  "type": "module",
  "bin": {
    "content-distribution-mcp": "./build/index.js"
  },
  "main": "./build/index.js",
  "files": [
    "build",
    "README.md",
    "LICENSE",
    "smithery.yaml"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); const f='build/index.js'; const c=fs.readFileSync(f,'utf8'); if(!c.startsWith('#!')) fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\"",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "prepublishOnly": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "keywords": [
    "mcp",
    "content-distribution",
    "social-media",
    "linkedin",
    "instagram",
    "twitter",
    "tiktok",
    "ai-agent",
    "automation",
    "content-marketing"
  ],
  "author": "Emmanuel Gomes Soares <hello@stresszeroentrepreneur.fr>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gomessoaresemmanuel-cpu/content-distribution-mcp"
  },
  "homepage": "https://github.com/gomessoaresemmanuel-cpu/content-distribution-mcp",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
